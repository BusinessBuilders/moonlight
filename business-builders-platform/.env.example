# ===========================================
# Business Builders Platform — Environment
# ===========================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://payload:payload_secret@localhost:5432/business_builders

# Payload CMS
PAYLOAD_SECRET=your-super-secret-payload-key-change-this

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Facebook Integration
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
NEXT_PUBLIC_FACEBOOK_APP_ID=
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=

# E-Signature (Dropbox Sign / HelloSign)
DROPBOX_SIGN_API_KEY=
DROPBOX_SIGN_CLIENT_ID=
NEXT_PUBLIC_DROPBOX_SIGN_CLIENT_ID=

# Cloudinary (Media CDN — optional, defaults to local uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis (Rate Limiting)
REDIS_URL=redis://localhost:6379

# Platform URL
NEXT_PUBLIC_PLATFORM_URL=http://localhost:3000

# ===========================================
# Client Site Environment (moonlight-farm)
# ===========================================
BB_API_URL=http://localhost:3000
BB_API_KEY=client_xxxxxxxxxxxx
BB_TENANT_ID=moonlight-farm
